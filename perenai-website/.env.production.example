# =============================================================================
# PEREN AI — Production AWS (peren.ai)
# Sur le serveur : cp .env.production.example .env && nano .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=perenai
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_32
POSTGRES_DB=perenai
FRONTEND_PORT=8080

# --- Backend ---
APP_ENV=production
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+psycopg2://perenai:CHANGE_ME_openssl_rand_hex_32@db:5432/perenai

# --- URLs peren.ai ---
FRONTEND_ORIGIN=https://peren.ai,https://www.peren.ai
GOOGLE_CALLBACK_URL=https://peren.ai/api/auth/google/callback
FRONTEND_GOOGLE_CALLBACK_PATH=/auth/callback

# --- Google OAuth (OBLIGATOIRE en production) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Payzone ---
PAYZONE_MERCHANT_ID=
PAYZONE_SECRET_KEY=
PAYZONE_BASE_URL=https://secure.payzone.ma/payment
PAYZONE_API_URL=https://api.payzone.ma
PAYZONE_CALLBACK_URL=https://peren.ai/api/payments/callback
PAYZONE_RETURN_SUCCESS_URL=https://peren.ai/payment/success
PAYZONE_RETURN_FAILURE_URL=https://peren.ai/payment/failure

# --- PayPal (optionnel) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live

PAYMENT_WEBHOOK_SECRET=CHANGE_ME_openssl_rand_hex_32

EMAIL_USER=
EMAIL_PASS=

# --- Frontend build args (rebuild après modification) ---
VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_PLAN_ID_MONTHLY=
VITE_PAYPAL_PLAN_ID_QUARTERLY=
VITE_PAYPAL_PLAN_ID_YEARLY=

# --- OpenAI (recommandations IA, scans, biomarqueurs) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
