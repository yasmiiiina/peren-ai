FROM node:20-alpine AS builder

WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install

COPY . .
ARG VITE_API_URL=/api
ARG VITE_GOOGLE_CLIENT_ID=
ARG VITE_PAYPAL_CLIENT_ID=
ARG VITE_PAYPAL_PLAN_ID_MONTHLY=
ARG VITE_PAYPAL_PLAN_ID_QUARTERLY=
ARG VITE_PAYPAL_PLAN_ID_YEARLY=
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_GOOGLE_CLIENT_ID=${VITE_GOOGLE_CLIENT_ID}
ENV VITE_PAYPAL_CLIENT_ID=${VITE_PAYPAL_CLIENT_ID}
ENV VITE_PAYPAL_PLAN_ID_MONTHLY=${VITE_PAYPAL_PLAN_ID_MONTHLY}
ENV VITE_PAYPAL_PLAN_ID_QUARTERLY=${VITE_PAYPAL_PLAN_ID_QUARTERLY}
ENV VITE_PAYPAL_PLAN_ID_YEARLY=${VITE_PAYPAL_PLAN_ID_YEARLY}
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
RUN chmod -R a+r /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
