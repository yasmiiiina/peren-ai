# =============================================================================
# PEREN AI — Variables d'environnement (template)
# Copier vers .env : cp .env.example .env
# NE JAMAIS committer .env avec des secrets réels
# =============================================================================

# --- PostgreSQL (production Docker) ---
POSTGRES_USER=perenai
POSTGRES_PASSWORD=
POSTGRES_DB=perenai
FRONTEND_PORT=8080

# --- Backend ---
APP_ENV=development
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Dev local SQLite :
DATABASE_URL=sqlite:///./perenai.db
# Production Docker (auto via docker-compose) :
# DATABASE_URL=postgresql+psycopg2://perenai:PASSWORD@db:5432/perenai

# --- URLs publiques ---
# Dev (Vite proxy) :
FRONTEND_ORIGIN=http://localhost:5173
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/google/callback
# Production AWS (peren.ai) :
# FRONTEND_ORIGIN=https://peren.ai
# GOOGLE_CALLBACK_URL=https://peren.ai/api/auth/google/callback
FRONTEND_GOOGLE_CALLBACK_PATH=/auth/callback

# --- Google OAuth (console.cloud.google.com) ---
# Laisser VIDE en dev → mock Google automatique
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Payzone (Maroc) ---
PAYZONE_MERCHANT_ID=
PAYZONE_SECRET_KEY=
PAYZONE_BASE_URL=https://secure.payzone.ma/payment
PAYZONE_API_URL=https://api.payzone.ma
PAYZONE_CALLBACK_URL=http://localhost:5173/api/payments/callback
PAYZONE_RETURN_SUCCESS_URL=http://localhost:5173/payment/success
PAYZONE_RETURN_FAILURE_URL=http://localhost:5173/payment/failure

# --- PayPal (optionnel) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# --- Webhook paiement (obligatoire en production) ---
PAYMENT_WEBHOOK_SECRET=

# --- Email (optionnel) ---
EMAIL_USER=
EMAIL_PASS=

# --- Frontend (build Vite / Docker) ---
VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_PLAN_ID_MONTHLY=
VITE_PAYPAL_PLAN_ID_QUARTERLY=
VITE_PAYPAL_PLAN_ID_YEARLY=

# --- IA (OpenAI — recommandations Digital Twin, scans, biomarqueurs) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
